# ─── Required ───────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DATABASE_URL=sqlite:///taskhive.db   # Railway will auto-set PostgreSQL URL

# ─── Admin Account ───────────────────────────────────
ADMIN_EMAIL=admin@taskhive.com
ADMIN_PASSWORD=ChangeMe123!

# ─── Google OAuth (optional) ─────────────────────────
# Get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── IntaSend Payments ────────────────────────────────
# Get from https://intasend.com
# Leave blank for sandbox/test mode (auto-credits wallet)
INTASEND_API_KEY=
INTASEND_PUBLISHABLE_KEY=
INTASEND_TEST=true    # Set to false for live payments

# ─── App Config ──────────────────────────────────────
FLASK_ENV=production
PORT=5000
